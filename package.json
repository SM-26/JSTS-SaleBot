    "@cypress/request": "^3.0.0",
    "qs": "^6.14.2",
    "tough-cookie": "^4.1.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mongoose": "^9.4.1",
    "node-telegram-bot-api": "^0.67.0"
